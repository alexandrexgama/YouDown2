# Configurações do YouDow
USE_NGROK=False
NGROK_AUTHTOKEN=seu_token_aqui
FLASK_PORT=5000

# Opcional: autenticação do yt-dlp para plataformas que bloqueiam acesso anônimo
# Preferencial: use um cookies.txt na raiz do projeto ou informe o caminho abaixo
YTDLP_COOKIEFILE=
# Alternativa opcional baseada em navegador
YTDLP_COOKIES_FROM_BROWSER=
